generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────
// Auth & Users
// ─────────────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  name        String
  title       String?
  email       String    @unique
  password    String
  avatarUrl   String?
  role        String    @default("client") // developer | super_admin | admin | client
  department  String? // "Design" | "Account Management" | "Development" | "Leadership" | "Marketing" | "Sales" | "Operations"
  accountKeys String    @default("[]") // JSON array of assigned account keys
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  invites  UserInvite[]
  accounts Account[] // accounts where this user is the rep

  templatesCreated   Template[]                  @relation("TemplateCreatedBy")
  templatesUpdated   Template[]                  @relation("TemplateUpdatedBy")
  templatesPublished Template[]                  @relation("TemplatePublishedBy")
  templateVersions   TemplateVersion[]           @relation("TemplateVersionCreatedBy")
  dashboardLayouts DashboardLayoutPreference[]

  metaPacerOwnerAds            MetaAdsPacerAd[]          @relation("MetaPacerOwner")
  metaPacerDesignerAds         MetaAdsPacerAd[]          @relation("MetaPacerDesigner")
  metaPacerAccountRepAds       MetaAdsPacerAd[]          @relation("MetaPacerAccountRep")
  metaPacerDesignNotesAuthored MetaAdsPacerDesignNote[]  @relation("MetaPacerDesignNoteAuthor")
  metaPacerActivityAuthored    MetaAdsPacerActivityLog[] @relation("MetaPacerActivityAuthor")
  metaPacerAccountNotes        MetaAdsPacerAccountNote[] @relation("MetaPacerAccountNoteAuthor")
  metaPacerBudgetLogs          MetaAdsPacerBudgetLog[]   @relation("MetaPacerBudgetLogAuthor")
  notifications                Notification[]
  notificationPreferences      NotificationPreference[]
}

model UserInvite {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  sentAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model DashboardLayoutPreference {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String
  mode       String
  scopeKey   String
  orderJson  String   @default("[]")
  hiddenJson String   @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, role, mode, scopeKey])
  @@index([userId, updatedAt])
}

// ─────────────────────────────────────────────────────
// Accounts (formerly rooftops.json)
// ─────────────────────────────────────────────────────

model Account {
  id           String   @id @default(cuid())
  key          String   @unique // "youngHonda", "smithToyota"
  slug         String?  @unique // URL-safe kebab-case: "young-honda"
  dealer       String // "Young Honda"
  category     String? // "Automotive", "Healthcare", etc.
  oem          String? // single OEM key
  oems         String? // JSON array of OEM keys for multi-brand dealers
  email        String?
  phone        String?
  salesPhone   String?
  servicePhone String?
  partsPhone   String?
  address      String?
  city         String?
  state        String?
  postalCode   String?
  website      String?
  timezone     String?
  logos        String? // JSON: { light, dark, white?, black? }
  branding     String? // JSON: { colors: { primary, secondary, ... }, fonts: { heading, body } }
  customValues String? // JSON: Record<string, { name, value }>
  // Markup rate used by Meta Ads Pacer budget math: actual spend =
  // client gross × markup. Falls back to the global default (0.77) when
  // null. Settable per-account so stores with non-standard markups don't
  // need code changes.
  markup       Float?
  espProvider  String // active provider id (must match a registered adapter)
  // Sending identity for Loomi-native email sends. When null, falls back to
  // SMTP_FROM / global defaults. Configure per-subaccount once DKIM/SPF for
  // sendingDomain is set up in the client's DNS.
  senderEmail   String?
  senderName    String?
  sendingDomain String?
  replyToEmail  String?
  // Per-sub-account SendGrid API key (AES-256-GCM encrypted at rest via
  // src/lib/esp/encryption.ts). When present, the worker sends through
  // SendGrid instead of falling back to SMTP. sendgridFromDomain stores the
  // verified sender domain so we can warn at send time if senderEmail isn't
  // authenticated.
  sendgridApiKey     String?
  sendgridFromDomain String?
  accountRepId String?
  accountRep   User?    @relation(fields: [accountRepId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  emails                  AccountEmail[]
  espConnections          EspConnection[]
  espOAuthConnections     EspOAuthConnection[]
  espAccountProviderLinks EspAccountProviderLink[]
  audiences               Audience[]
  loomiFlows              LoomiFlow[]
  espTemplates            EspTemplate[]
  espTemplateFolders      EspTemplateFolder[]
  mediaAssets             MediaAsset[]
  metaAdsPacerPlan        MetaAdsPacerPlan?
  metaAdsPacerAccountNotes MetaAdsPacerAccountNote[]
  metaAdsPacerBudgetLogs   MetaAdsPacerBudgetLog[]

  @@index([accountRepId])
}

model YagRollupConfig {
  id                    String    @id @default(cuid())
  singletonKey          String    @unique @default("primary")
  targetAccountKey      String
  sourceAccountKeys     String    @default("[]") // JSON array of account keys to roll up into target
  enabled               Boolean   @default(true)
  scheduleIntervalHours Int       @default(1) // incremental sync cadence in UTC hours
  scheduleMinuteUtc     Int       @default(15) // minute past the hour for incremental sync
  fullSyncEnabled       Boolean   @default(true)
  fullSyncHourUtc       Int       @default(3) // UTC hour for daily full reconcile
  fullSyncMinuteUtc     Int       @default(45) // UTC minute for daily full reconcile
  scrubInvalidEmails    Boolean   @default(true)
  scrubInvalidPhones    Boolean   @default(true)
  updatedByUserId       String?
  lastSyncedAt          DateTime?
  lastSyncStatus        String?
  lastSyncSummary       String?
  currentRunStartedAt   DateTime? // null = idle, non-null = sync/wipe in progress since this time
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model YagRollupConfigHistory {
  id                     String   @id @default(cuid())
  configSingletonKey     String   @default("primary")
  targetAccountKey       String
  sourceAccountKeys      String // JSON array
  enabled                Boolean
  scheduleIntervalHours  Int
  scheduleMinuteUtc      Int
  fullSyncEnabled        Boolean
  fullSyncHourUtc        Int
  fullSyncMinuteUtc      Int
  scrubInvalidEmails     Boolean
  scrubInvalidPhones     Boolean
  changedFields          String   @default("[]") // JSON array of changed field keys
  changedByUserId        String?
  changedByUserName      String?
  changedByUserEmail     String?
  changedByUserRole      String?
  changedByUserAvatarUrl String?
  createdAt              DateTime @default(now())

  @@index([configSingletonKey, createdAt])
  @@index([changedByUserId, createdAt])
}

model YagRollupRunHistory {
  id                       String   @id @default(cuid())
  configSingletonKey       String   @default("primary")
  runType                  String // sync | wipe
  status                   String // ok | failed | disabled
  dryRun                   Boolean  @default(false)
  fullSync                 Boolean?
  wipeMode                 String? // tagged | all
  triggerSource            String?
  targetAccountKey         String?
  sourceAccountKeys        String? // JSON array
  totals                   String? // JSON object
  errors                   String? // JSON object
  triggeredByUserId        String?
  triggeredByUserName      String?
  triggeredByUserEmail     String?
  triggeredByUserRole      String?
  triggeredByUserAvatarUrl String?
  startedAt                DateTime
  finishedAt               DateTime
  createdAt                DateTime @default(now())

  @@index([configSingletonKey, createdAt])
  @@index([runType, createdAt])
  @@index([triggeredByUserId, createdAt])
}

// ─────────────────────────────────────────────────────
// ESP Connections (API-key-based providers)
// ─────────────────────────────────────────────────────

model EspConnection {
  id          String   @id @default(cuid())
  accountKey  String
  account     Account  @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  provider    String // provider id
  apiKey      String // encrypted at rest (AES-256-GCM)
  accountId   String? // provider-specific account identifier
  accountName String?
  metadata    String? // JSON for provider-specific extras
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountKey, provider])
  @@index([provider])
  @@index([accountKey])
}

model EspOAuthConnection {
  id             String   @id @default(cuid())
  accountKey     String
  account        Account  @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  provider       String // provider id
  locationId     String?
  locationName   String?
  accessToken    String // encrypted at rest (AES-256-GCM)
  refreshToken   String // encrypted at rest (AES-256-GCM)
  tokenExpiresAt DateTime
  scopes         String   @default("[]") // JSON array of granted scopes
  installedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([accountKey, provider])
  @@index([provider])
  @@index([accountKey])
}

model EspProviderOAuthCredential {
  id             String   @id @default(cuid())
  provider       String   @unique // provider id
  subjectType    String? // provider-specific credential scope (e.g. "agency")
  subjectId      String? // provider-specific subject id (e.g. companyId)
  accessToken    String // encrypted at rest (AES-256-GCM)
  refreshToken   String // encrypted at rest (AES-256-GCM)
  tokenExpiresAt DateTime
  scopes         String   @default("[]") // JSON array of granted scopes
  installedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model EspAccountProviderLink {
  id           String   @id @default(cuid())
  accountKey   String
  account      Account  @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  provider     String // provider id
  locationId   String?
  locationName String?
  metadata     String? // provider-specific mapping metadata
  linkedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([accountKey, provider])
  @@index([provider])
  @@index([accountKey])
}

// ─────────────────────────────────────────────────────
// Template Library
// ─────────────────────────────────────────────────────

model Template {
  id                String    @id @default(cuid())
  slug              String    @unique // "service-reminder", "modern-dark"
  title             String // "Service Reminder", "Modern Dark"
  type              String // "lifecycle" | "design"
  category          String? // "service", "sales", "loyalty", etc.
  content           String // full raw HTML template source
  preheader         String?
  published         Boolean   @default(false)
  publishedAt       DateTime?
  publishedByUserId String?
  createdByUserId   String?
  updatedByUserId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  createdByUser   User?                   @relation("TemplateCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser   User?                   @relation("TemplateUpdatedBy", fields: [updatedByUserId], references: [id])
  publishedByUser User?                   @relation("TemplatePublishedBy", fields: [publishedByUserId], references: [id])
  versions        TemplateVersion[]
  tags            TemplateTagAssignment[]
  emails          AccountEmail[]

  @@index([published])
}

model TemplateVersion {
  id              String   @id @default(cuid())
  templateId      String
  template        Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  content         String // snapshot of full HTML at this version
  createdByUserId String?
  createdAt       DateTime @default(now())

  createdByUser User? @relation("TemplateVersionCreatedBy", fields: [createdByUserId], references: [id])

  @@index([templateId])
}

// ─────────────────────────────────────────────────────
// Template Tags
// ─────────────────────────────────────────────────────

model TemplateTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  assignments TemplateTagAssignment[]
}

model TemplateTagAssignment {
  id         String      @id @default(cuid())
  templateId String
  template   Template    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tagId      String
  tag        TemplateTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([templateId, tagId])
}

// ─────────────────────────────────────────────────────
// Account Emails (template instances per account)
// ─────────────────────────────────────────────────────

model AccountEmail {
  id         String       @id @default(cuid())
  accountKey String
  account    Account      @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  templateId String
  template   Template     @relation(fields: [templateId], references: [id])
  name       String // "Service Reminder - Young Honda"
  content    String? // null = use library template, non-null = customized copy
  status     String       @default("draft") // draft | active | archived
  folderId   String?
  folder     EmailFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([accountKey])
  @@index([templateId])
}

// ─────────────────────────────────────────────────────
// Email Folders
// ─────────────────────────────────────────────────────

model EmailFolder {
  id         String   @id @default(cuid())
  name       String
  accountKey String? // null = global folder
  createdAt  DateTime @default(now())

  emails AccountEmail[]

  @@unique([name, accountKey])
}

// ─────────────────────────────────────────────────────
// Audiences (saved contact filters)
// ─────────────────────────────────────────────────────

model Audience {
  id               String   @id @default(cuid())
  name             String
  description      String?
  accountKey       String?
  account          Account? @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  createdByUserId  String?
  filters          String // JSON: FilterDefinition
  icon             String?
  color            String?
  sortOrder        Int      @default(0)
  providerMetadata String? // JSON map for provider-specific audience refs
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([name, accountKey])
  @@index([accountKey])
}

// ─────────────────────────────────────────────────────
// Loomi Flows (native flow definitions managed in Loomi)
// ─────────────────────────────────────────────────────

model LoomiFlow {
  id               String    @id @default(cuid())
  name             String
  description      String?
  status           String    @default("inactive") // active | inactive
  accountKey       String?
  account          Account?  @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  createdByUserId  String?
  sourceAudienceId String?
  sourceFilter     String?
  metadata         String?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([accountKey])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────
// SMS Campaigns (bulk + scheduled outbound)
// ─────────────────────────────────────────────────────

model SmsCampaign {
  id               String    @id @default(cuid())
  name             String?
  message          String
  status           String    @default("queued") // queued | scheduled | processing | completed | partial | failed | canceled
  scheduledFor     DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  createdByUserId  String?
  createdByRole    String?
  sourceAudienceId String?
  sourceFilter     String?
  accountKeys      String    @default("[]") // JSON array of account keys
  totalRecipients  Int       @default(0)
  sentCount        Int       @default(0)
  failedCount      Int       @default(0)
  metadata         String?
  error            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  recipients SmsCampaignRecipient[]

  @@index([status, scheduledFor])
  @@index([createdAt])
}

model SmsCampaignRecipient {
  id             String      @id @default(cuid())
  campaignId     String
  campaign       SmsCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId      String
  accountKey     String
  phone          String?
  fullName       String?
  status         String      @default("pending") // pending | sent | failed | skipped
  messageId      String?
  conversationId String?
  sentAt         DateTime?
  error          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([campaignId, contactId, accountKey])
  @@index([campaignId, status])
  @@index([accountKey, status])
}

// ─────────────────────────────────────────────────────
// Email Campaigns (bulk + scheduled outbound)
// ─────────────────────────────────────────────────────

model EmailCampaign {
  id               String    @id @default(cuid())
  name             String?
  subject          String
  previewText      String?
  htmlContent      String
  textContent      String?
  sourceType       String    @default("template-library") // template-library | drag-drop | html
  status           String    @default("queued") // queued | scheduled | processing | completed | partial | failed | canceled
  scheduledFor     DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  createdByUserId  String?
  createdByRole    String?
  sourceAudienceId String?
  sourceFilter     String?
  accountKeys      String    @default("[]") // JSON array of account keys
  totalRecipients  Int       @default(0)
  sentCount        Int       @default(0)
  failedCount      Int       @default(0)
  metadata         String?
  error            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  recipients EmailCampaignRecipient[]

  @@index([status, scheduledFor])
  @@index([createdAt])
}

model EmailCampaignRecipient {
  id         String        @id @default(cuid())
  campaignId String
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  String
  accountKey String
  email      String?
  fullName   String?
  status     String        @default("pending") // pending | sent | failed | skipped
  messageId  String?
  sentAt     DateTime?
  error      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  events EmailEvent[]

  @@unique([campaignId, contactId, accountKey])
  @@index([campaignId, status])
  @@index([accountKey, status])
}

// One row per SendGrid Event Webhook entry. We retain the raw payload
// so we can rebuild parsed columns if the schema evolves. recipientId
// is nullable to accommodate events for SendGrid traffic that wasn't
// produced by a Loomi campaign (e.g. transactional sends by the client
// through the same API key) — they're still logged for audit.
model EmailEvent {
  id          String   @id @default(cuid())
  campaignId  String?
  recipientId String?
  recipient   EmailCampaignRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  accountKey  String?
  eventType   String // delivered | open | click | bounce | dropped | spamreport | unsubscribe | deferred | processed
  sgEventId   String   @unique // SendGrid's sg_event_id; the idempotency key
  sgMessageId String?
  email       String?
  timestamp   DateTime
  url         String? // populated for click events
  reason      String? // populated for bounce / dropped
  userAgent   String?
  ip          String?
  raw         String // full event payload as JSON for forensics
  createdAt   DateTime @default(now())

  @@index([campaignId, eventType])
  @@index([recipientId])
  @@index([accountKey, eventType])
  @@index([sgMessageId])
  @@index([timestamp])
}

// Persistent per-account suppression list. The recipient resolver pulls
// these emails out of every campaign batch before send. Bounce + spam
// reports auto-populate from the webhook; unsubscribe + manual entries
// flow through other surfaces.
model EmailSuppression {
  id         String   @id @default(cuid())
  accountKey String
  email      String
  reason     String // bounce | spamreport | unsubscribe | manual
  source     String   @default("sendgrid") // sendgrid | manual
  raw        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([accountKey, email])
  @@index([email])
}

// ─────────────────────────────────────────────────────
// ESP Templates (synced from GHL / Klaviyo)
// ─────────────────────────────────────────────────────

model EspTemplate {
  id           String    @id @default(cuid())
  accountKey   String
  account      Account   @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  provider     String // primary provider at creation time
  remoteId     String? // legacy — use publishedTo for multi-ESP
  publishedTo  String? // JSON: {"ghl":"remote-id","klaviyo":"remote-id"}
  name         String
  subject      String?
  previewText  String?
  html         String    @default("")
  source       String? // Maizzle markup for visual/D&D templates (null = HTML-only)
  status       String    @default("draft")
  editorType   String? // 'visual' | 'code'
  thumbnailUrl String?
  folderId     String?
  folder       EspTemplateFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([accountKey, provider, remoteId])
  @@index([accountKey])
  @@index([provider])
  @@index([folderId])
}

model EspTemplateFolder {
  id         String   @id @default(cuid())
  accountKey String
  account    Account  @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  name       String
  parentId   String?
  parent     EspTemplateFolder?  @relation("FolderParent", fields: [parentId], references: [id], onDelete: SetNull)
  children   EspTemplateFolder[] @relation("FolderParent")
  remoteId   String? // GHL remote folder ID (set when synced from ESP)
  templates  EspTemplate[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([accountKey])
  @@index([parentId])
  @@unique([accountKey, remoteId])
}

// ─────────────────────────────────────────────────────
// Changelog
// ─────────────────────────────────────────────────────

model ChangelogEntry {
  id          String   @id @default(cuid())
  title       String
  content     String // Plain text body describing the change
  type        String   @default("improvement") // feature | improvement | fix
  publishedAt DateTime @default(now())
  createdBy   String? // user name or "Claude"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt])
}

// ─────────────────────────────────────────────────────
// S3 Media Assets (supplementary storage alongside ESP)
// ─────────────────────────────────────────────────────

model MediaAsset {
  id           String   @id @default(cuid())
  accountKey   String? // null = admin-level (Loomi media library)
  account      Account? @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  s3Key        String // "media/_admin/{id}/{filename}" or "media/{accountKey}/{id}/{filename}"
  filename     String
  mimeType     String
  size         Int // bytes
  width        Int? // image-only
  height       Int? // image-only
  thumbnailKey String? // "media/_admin/{id}/thumb.webp"
  category     String? // "brand" | "ad-creative" | "oem" | "general"
  tags         String? // JSON string[] for future DAM filtering
  uploadedBy   String? // User ID
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([s3Key])
  @@index([accountKey, createdAt])
  @@index([accountKey, category])
}

// ─────────────────────────────────────────────────────
// Meta Ads Pacer
// ─────────────────────────────────────────────────────

model MetaAdsPacerPlan {
  id              String   @id @default(cuid())
  accountKey      String   @unique
  account         Account  @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  baseBudgetGoal  String? // legacy account-wide default (replaced by MetaAdsPacerPeriodBudget per-month entries)
  addedBudgetGoal String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ads           MetaAdsPacerAd[]
  periodBudgets MetaAdsPacerPeriodBudget[]
}

model MetaAdsPacerPeriodBudget {
  id              String           @id @default(cuid())
  planId          String
  plan            MetaAdsPacerPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  period          String // YYYY-MM, e.g. "2026-04"
  baseBudgetGoal  String?
  addedBudgetGoal String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([planId, period])
  @@index([planId, period])
}

model MetaAdsPacerAd {
  id       String           @id @default(cuid())
  planId   String
  plan     MetaAdsPacerPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  position Int              @default(0)

  name String @default("")

  // Assignments
  ownerUserId      String?
  owner            User?   @relation("MetaPacerOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  designerUserId   String?
  designer         User?   @relation("MetaPacerDesigner", fields: [designerUserId], references: [id], onDelete: SetNull)
  accountRepUserId String?
  accountRep       User?   @relation("MetaPacerAccountRep", fields: [accountRepUserId], references: [id], onDelete: SetNull)

  // Planning
  period       String  @default("") // YYYY-MM bucket — primary planning axis
  month        String? // legacy month-name tag, retained for backwards compat
  actionNeeded String?
  recurring    String  @default("No") // Yes | No | Unknown
  coop         String  @default("No") // Yes | No | Unknown
  budgetType   String  @default("Daily") // Daily | Lifetime
  // base | added | split. When "split", the ad's allocation is divided
  // between the two budget pools — splitBaseAmount goes to Base, the
  // rest goes to Added. pacerActual splits proportionally to keep both
  // pools' over/under math accurate.
  budgetSource    String  @default("base")
  splitBaseAmount String?

  // Dates (ISO yyyy-MM-dd strings to mirror <input type="date">)
  flightStart     String?
  flightEnd       String?
  liveDate        String?
  creativeDueDate String?
  dueDate         String? // overall ad due date — auto-calc 2 business days before flightStart
  dateCompleted   String?

  // Status
  adStatus         String @default("In Draft")
  designStatus     String @default("Not Started")
  internalApproval String @default("Pending Approval")
  clientApproval   String @default("Pending Approval")

  // Money (string to mirror form input, parsed at calc time)
  allocation       String?
  pacerActual      String?
  pacerDailyBudget String?

  // Pacer-only date scoping: lets the user adjust "today" and "end" per ad
  // without affecting the Ad Planner flight dates.
  pacerTodayDate String?
  pacerEndDate   String?

  // Other
  creativeLink    String?
  clientName      String?
  digitalDetails  String? // long-form notes from the rep about the ad goal/plan

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  designNotes MetaAdsPacerDesignNote[]
  activityLog MetaAdsPacerActivityLog[]

  @@index([planId, period, position])
  @@index([planId, position])
  @@index([adStatus])
  @@index([designerUserId])
  @@index([ownerUserId])
}

model MetaAdsPacerDesignNote {
  id           String         @id @default(cuid())
  adId         String
  ad           MetaAdsPacerAd @relation(fields: [adId], references: [id], onDelete: Cascade)
  text         String
  authorUserId String?
  author       User?          @relation("MetaPacerDesignNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())

  @@index([adId, createdAt])
}

model MetaAdsPacerActivityLog {
  id                 String         @id @default(cuid())
  adId               String
  ad                 MetaAdsPacerAd @relation(fields: [adId], references: [id], onDelete: Cascade)
  text               String
  attachmentKey      String? // S3 key when an attachment was uploaded
  attachmentFilename String?
  attachmentMimeType String?
  attachmentSize     Int?
  authorUserId       String?
  author             User?          @relation("MetaPacerActivityAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime       @default(now())

  @@index([adId, createdAt])
}

// Account-level chat log for the Meta Ads Pacer. Distinct from the
// per-ad DesignNote / ActivityLog — these notes live on the account
// itself so reps can capture context that applies to the whole pacing
// view (variance explanations, client conversations, etc).
model MetaAdsPacerAccountNote {
  id           String   @id @default(cuid())
  accountKey   String
  account      Account  @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  text         String
  authorUserId String?
  author       User?    @relation("MetaPacerAccountNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([accountKey, createdAt])
}

// Budget log — point-in-time snapshot of the pacer's spend + client
// budget numbers, captured by reps as a record of when they checked or
// adjusted budgets during the month. Scoped per-account + per-period
// (YYYY-MM) so each month's checks live as their own thread.
model MetaAdsPacerBudgetLog {
  id           String   @id @default(cuid())
  accountKey   String
  account      Account  @relation(fields: [accountKey], references: [key], onDelete: Cascade)
  period       String // YYYY-MM
  // JSON-encoded AdSnapshot[] — per-ad numbers matching the Summary tab
  // columns (budgetType, budget, projected, actual, target, recDaily).
  // See BudgetLogDrawer for the exact shape.
  adsSnapshot  String   @default("[]")
  // Optional free-text context — "rebalanced after client call", etc.
  note         String?
  authorUserId String?
  author       User?    @relation("MetaPacerBudgetLogAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([accountKey, period, createdAt])
}

// ─────────────────────────────────────────────────────
// Notifications (in-app + email)
// ─────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // ad_due_soon | ad_overdue | approval_pending | status_stuck | pacing_alert | period_over_allocated | ad_assigned | approval_changed
  severity  String    @default("info") // info | warning | critical
  title     String
  body      String?
  link      String? // optional in-app link (e.g. /tools/meta-ads-pacer?adId=…)
  metaJson  String? // optional JSON payload for the originating event (adId, accountKey, etc)
  emailedAt DateTime?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
}
