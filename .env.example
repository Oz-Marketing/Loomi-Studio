# Core
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/loomi_studio?schema=public"
NEXTAUTH_URL="http://127.0.0.1:3000"
NEXTAUTH_SECRET="replace-with-random-secret"
INTERNAL_JOB_SECRET="replace-with-long-random-secret"

# Surface hosts — the proxy (src/proxy.ts) routes by Host header. Leave unset
# in dev/prod (sensible defaults below apply); set explicitly only where the
# sibling-subdomain convention doesn't hold (e.g. staging's app-staging.*).
#   Studio (base):  studio.loomilm.com  (dev: localhost:3000)        APP_HOST / NEXT_PUBLIC_APP_HOST
#   App (admin):    app.loomilm.com     (dev: app.localhost:3000)    APP_SURFACE_HOST / NEXT_PUBLIC_APP_SURFACE_HOST
#   Reporting:      reporting.loomilm.com                            REPORTING_HOST / NEXT_PUBLIC_REPORTING_HOST
#   Marketing:      loomilm.com apex    (dev: marketing.localhost:3000)
# NEXT_PUBLIC_MARKETING_HOST="loomilm.com"

# Token encryption (Twilio + SendGrid credentials at rest)
TOKEN_ENCRYPTION_SECRET="replace-with-64-char-random-hex"

# AI
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"

# SMTP (test sends + campaign mail)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# User onboarding invites
USER_INVITE_TTL_HOURS="72"

# Meta (Facebook) Marketing API — Ad Pacer spend sync (read-only)
# Agency-wide System User token with `ads_read` on the client ad accounts.
# Each sub-account links its own ad account via Account.metaAdAccountId
# ("act_123…"), set in the account's settings — not here.
META_SYSTEM_USER_TOKEN=""
# Optional, strongly recommended: the Meta App secret. Enables appsecret_proof
# on every Graph call (server-side request signing).
META_APP_SECRET=""
# Optional: pin the Graph API version (defaults to v21.0).
META_API_VERSION="v21.0"

# S3 Media Storage (template assets, uploaded images)
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""              # Optional: for S3-compatible providers (R2, MinIO)
S3_PUBLIC_URL_PREFIX=""      # Optional: CloudFront/custom domain for public URLs

# One-off migration helper (SQLite -> Postgres)
# SQLITE_SOURCE_PATH="/tmp/loomi-dev.db"

# Dashboard local testing
# NEXT_PUBLIC_DASHBOARD_DUMMY_DATA="0"

# Feature flags (off unless set to "true"). Set per-environment; leave unset in
# production until the feature is ready to ship.
# Ad Generator (/tools/ad-generator) — nav link hidden + route 404s when off.
# NEXT_PUBLIC_ENABLE_AD_GENERATOR="true"
