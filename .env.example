# Core
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/loomi_studio?schema=public"
NEXTAUTH_URL="http://127.0.0.1:3000"
NEXTAUTH_SECRET="replace-with-random-secret"
INTERNAL_JOB_SECRET="replace-with-long-random-secret"

# Token encryption (Twilio + SendGrid credentials at rest)
TOKEN_ENCRYPTION_SECRET="replace-with-64-char-random-hex"

# AI
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"

# SMTP (test sends + campaign mail)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# User onboarding invites
USER_INVITE_TTL_HOURS="72"

# S3 Media Storage (template assets, uploaded images)
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""              # Optional: for S3-compatible providers (R2, MinIO)
S3_PUBLIC_URL_PREFIX=""      # Optional: CloudFront/custom domain for public URLs

# One-off migration helper (SQLite -> Postgres)
# SQLITE_SOURCE_PATH="/tmp/loomi-dev.db"

# Dashboard local testing
# NEXT_PUBLIC_DASHBOARD_DUMMY_DATA="0"

# YAG rollup sync tuning
YAG_ROLLUP_SOURCE_ACCOUNT_CONCURRENCY="3"
YAG_ROLLUP_TARGET_UPSERT_CONCURRENCY="4"
YAG_ROLLUP_MAX_SOURCE_CONTACTS_PER_ACCOUNT="50000"
YAG_ROLLUP_MAX_UPSERTS_PER_RUN="10000"
YAG_ROLLUP_INCREMENTAL_LOOKBACK_HOURS="48"
YAG_ROLLUP_TARGET_DELETE_CONCURRENCY="4"
YAG_ROLLUP_MAX_DELETES_PER_RUN="50000"
YAG_ROLLUP_MAX_TARGET_CONTACTS_FOR_WIPE="150000"
