{
  "name": "loomi-studio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && prisma db push --accept-data-loss && npx tsx scripts/backfill-slugs.ts && npx tsx scripts/seed-changelog-entries.ts && next build --webpack",
    "build:assets": "prisma generate && next build --webpack",
    "deploy:prepare": "prisma generate && prisma db push --accept-data-loss && npx tsx scripts/backfill-slugs.ts && npx tsx scripts/seed-changelog-entries.ts",
    "start": "next start -p 3000",
    "worker:start": "node --import tsx src/worker/index.ts",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:migrate:sqlite-to-postgres": "npx tsx scripts/migrate-sqlite-to-postgres.ts",
    "verify": "npx tsc --noEmit && npx tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "verify:build": "npm run verify && npx prisma generate && npx next build --webpack",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.998.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sparticuz/chromium": "^143.0.4",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.13",
    "@xyflow/react": "^12.10.2",
    "apexcharts": "^5.6.0",
    "autoprefixer": "^10.4.24",
    "bcryptjs": "^3.0.3",
    "dagre": "^0.8.5",
    "isomorphic-dompurify": "^3.14.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "papaparse": "^5.5.3",
    "pg-boss": "^12.18.2",
    "postcss": "^8.5.6",
    "puppeteer": "^24.37.3",
    "puppeteer-core": "^24.37.5",
    "react": "^19.0.0",
    "react-apexcharts": "^2.0.1",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "swr": "^2.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^7.0.9",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.16.0",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.31.1",
    "dotenv": "^17.3.1",
    "monaco-editor": "^0.55.1",
    "prisma": "^7.4.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "next-auth": {
      "next": "$next"
    }
  }
}
